# NASA API — get your key at https://api.nasa.gov (30-second form)
NASA_API_KEY=your_nasa_key_here

# Anthropic API — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Postgres connection (defaults match the local Docker Compose setup in Step 2)
DATABASE_URL=postgresql://observatory:observatory@localhost:5432/observatory
